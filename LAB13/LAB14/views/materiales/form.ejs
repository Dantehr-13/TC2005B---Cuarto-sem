<%- include('../includes/_header') %>

    <h2 class="title is-4">
        <%= editing ? 'Editar Material' : 'Nuevo Material' %>
    </h2>

    <form action="<%= editing ? '/materiales/' + material.clave + '/edit' : '/materiales/new' %>" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <% if (!editing) { %>
            <div class="field">
                <label for="clave" class="label">Clave</label>
                <div class="control">
                    <input id="clave" name="clave" class="input" type="number" placeholder="e.g. 1500" required>
                </div>
            </div>
            <% } else { %>
                <div class="field">
                    <label class="label">Clave</label>
                    <div class="control">
                        <input class="input" type="text" value="<%= material.clave %>" disabled>
                    </div>
                    <p class="help">La clave no se puede modificar</p>
                </div>
                <% } %>

                    <div class="field">
                        <label for="descripcion" class="label">Descripción</label>
                        <div class="control">
                            <input id="descripcion" name="descripcion" class="input" type="text"
                                placeholder="e.g. Varilla 3/16" value="<%= editing ? material.descripcion : '' %>"
                                required>
                        </div>
                    </div>

                    <div class="field">
                        <label for="precio" class="label">Precio</label>
                        <div class="control">
                            <input id="precio" name="precio" class="input" type="number" step="0.01"
                                placeholder="e.g. 100.00" value="<%= editing ? material.precio : '' %>" required>
                        </div>
                    </div>

                    <div class="field">
                        <label for="impuesto" class="label">Impuesto</label>
                        <div class="control">
                            <input id="impuesto" name="impuesto" class="input" type="number" step="0.01"
                                placeholder="e.g. 10.00" value="<%= editing ? material.impuesto : '' %>" required>
                        </div>
                    </div>

                    <div class="field is-grouped">
                        <div class="control">
                            <input class="button is-primary" type="submit"
                                value="<%= editing ? 'Actualizar' : 'Guardar' %>">
                        </div>
                        <div class="control">
                            <a class="button is-light" href="/materiales">Cancelar</a>
                        </div>
                    </div>
    </form>

    </div>
    </section>

    <%- include('../includes/_footer') %>