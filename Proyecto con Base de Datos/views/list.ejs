<%- include('includes/_header') %>

    <h2 class="title is-4">Personajes de League of Legends</h2>

    <!-- Botón para crear nuevo personaje (solo si tiene permiso) -->
    <% if (permisos && permisos.includes('crear_personaje')) { %>
        <a class="button is-primary mb-4" href="/personajes/new">＋ Nuevo personaje</a>
    <% } %>

    <div class="columns is-multiline mt-2">
        <% if (personajes.length > 0) { %>
            <% for (let p of personajes) { %>
                <div class="column is-one-third">
                    <div class="card">
                        <% if (p.imagen) { %>
                            <div class="card-image">
                                <figure class="image">
                                    <img src="/<%= p.imagen %>" alt="<%= p.nombre %>">
                                </figure>
                            </div>
                        <% } %>
                        <div class="card-content">
                            <p class="title is-5"><%= p.nombre %></p>
                            <span class="tag is-info"><%= p.tipo %></span>
                        </div>
                        <footer class="card-footer">
                            <a href="/personajes/<%= p.id %>" class="card-footer-item">Ver detalle</a>
                        </footer>
                    </div>
                </div>
            <% } %>
        <% } else { %>
            <div class="column">
                <div class="notification is-warning is-light">
                     No hay personajes registrados.
                </div>
            </div>
        <% } %>
    </div>

    </div>
    </section>

    <%- include('includes/_footer') %>