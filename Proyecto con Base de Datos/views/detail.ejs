<%- include('includes/_header') %>

    <h2 class="title is-4">Detalle del Personaje</h2>

    <div class="card">
        <% if (personaje.imagen) { %>
            <div class="card-image">
                <figure class="image">
                    <img src="/<%= personaje.imagen %>" alt="<%= personaje.nombre %>">
                </figure>
            </div>
            <% } %>
                <div class="card-content">
                    <div class="content">
                        <h3 class="title is-5">
                            <%= personaje.nombre %>
                        </h3>
                        <span class="tag is-info">
                            <%= personaje.tipo %>
                        </span>
                        <p class="mt-3">
                            <%= personaje.descripcion %>
                        </p>
                        <% if (championStats) { %>
                        <hr>
                        <p class="heading has-text-grey mb-2">Stats oficiales (Riot Games API)</p>
                        <div class="columns is-mobile is-multiline">
                            <div class="column is-half">
                                <p class="heading">Vida base</p>
                                <p class="title is-6"><%= championStats.hp %></p>
                            </div>
                            <div class="column is-half">
                                <p class="heading">Armadura</p>
                                <p class="title is-6"><%= championStats.armor %></p>
                            </div>
                            <div class="column is-half">
                                <p class="heading">Daño de ataque</p>
                                <p class="title is-6"><%= championStats.attackdamage %></p>
                            </div>
                            <div class="column is-half">
                                <p class="heading">Vel. de ataque</p>
                                <p class="title is-6"><%= championStats.attackspeed.toFixed(3) %></p>
                            </div>
                        </div>
                        <% } %>
                    </div>
                </div>
                <footer class="card-footer">
                    <a href="/personajes" class="card-footer-item">Volver a la lista</a>
                </footer>
    </div>

    </div>
    </section>

    <%- include('includes/_footer') %>